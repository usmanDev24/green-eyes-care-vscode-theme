{
    "$schema": "vscode://schemas/color-theme",
    "name": "Dark (Visual Studio)",
    "colors": {
        "checkbox.border": "#6B6B6B",
        "editor.background": "#1E1E1E",
        "editor.foreground": "#D4cac0",
        "editor.inactiveSelectionBackground": "#3A3D41",
        "editorIndentGuide.background1": "#404040",
        "editorIndentGuide.activeBackground1": "#707070",
        "editor.selectionHighlightBackground": "#ADD6FF26",
        "list.dropBackground": "#383B3D",
        "activityBarBadge.background": "#007ACC",
        "sideBarTitle.foreground": "#BBBBBB",
        "input.placeholderForeground": "#A6A6A6",
        "menu.background": "#252526",
        "menu.foreground": "#CCCCCC",
        "menu.separatorBackground": "#454545",
        "menu.border": "#454545",
        "statusBarItem.remoteForeground": "#FFF",
        "statusBarItem.remoteBackground": "#16825D",
        "ports.iconRunningProcessForeground": "#369432",
        "sideBarSectionHeader.background": "#0000",
        "sideBarSectionHeader.border": "#ccc3",
        "tab.selectedBackground": "#222222",
        "tab.selectedForeground": "#ffffffa0",
        "tab.lastPinnedBorder": "#ccc3",
        "list.activeSelectionIconForeground": "#FFF",
        "terminal.inactiveSelectionBackground": "#3A3D41",
        "widget.border": "#303031",
        "actionBar.toggledBackground": "#383a49"
    },
    "tokenColors": [
        {
            "scope": [
                "meta.embedded",
                "source.groovy.embedded",
                "string meta.image.inline.markdown",
                "variable.legacy.builtin.python"
            ],
            "settings": {
                "foreground": "#D4cac0"
            }
        },
        {
            "scope": "emphasis",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "strong",
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Readable Markdown/Doc Headers",
            "scope": "header",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#55bf60"
            }
        },
        {
            "scope": "comment",
            "settings": {
                "foreground": "#6A9955"
            }
        },
        {
            "name": "Language Constants (true, false, null) - Peach Separation",
            "scope": "constant.language",
            "settings": {
                "foreground": "#ff997a"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "variable.other.enummember",
                "keyword.operator.plus.exponent",
                "keyword.operator.minus.exponent"
            ],
            "settings": {
                "foreground": "#b5cea8"
            }
        },
        {
            "scope": "constant.regexp",
            "settings": {
                "foreground": "#6a956a"
            }
        },
        {
            "scope": "entity.name.tag",
            "settings": {
                "foreground": "#55bf60"
            }
        },
        {
            "scope": [
                "entity.name.tag.css",
                "entity.name.tag.less"
            ],
            "settings": {
                "foreground": "#d7ba7d"
            }
        },
        {
            "scope": "entity.other.attribute-name",
            "settings": {
                "foreground": "#9aebb8"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name.class.css",
                "source.css entity.other.attribute-name.class",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.parent-selector.css",
                "entity.other.attribute-name.parent.less",
                "source.css entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element.css",
                "source.css.less entity.other.attribute-name.id",
                "entity.other.attribute-name.scss"
            ],
            "settings": {
                "foreground": "#d7ba7d"
            }
        },
        {
            "scope": "invalid",
            "settings": {
                "foreground": "#f44747"
            }
        },
        {
            "scope": "markup.underline",
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "scope": "markup.bold",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#55bf60"
            }
        },
        {
            "scope": "markup.heading",
            "settings": {
                "fontStyle": "bold",
                "foreground": "#55bf60"
            }
        },
        {
            "scope": "markup.italic",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "markup.strikethrough",
            "settings": {
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#b5cea8"
            }
        },
        {
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#eba589"
            }
        },
        {
            "scope": "markup.changed",
            "settings": {
                "foreground": "#55bf60"
            }
        },
        {
            "scope": "punctuation.definition.quote.begin.markdown",
            "settings": {
                "foreground": "#5a6b99"
            }
        },
        {
            "scope": "punctuation.definition.list.begin.markdown",
            "settings": {
                "foreground": "#67e67b"
            }
        },
        {
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#eba589"
            }
        },
        {
            "name": "brackets of XML/HTML tags",
            "scope": "punctuation.definition.tag",
            "settings": {
                "foreground": "#808080"
            }
        },
        {
            "scope": [
                "meta.preprocessor",
                "entity.name.function.preprocessor"
            ],
            "settings": {
                "foreground": "#55bf60"
            }
        },
        {
            "scope": "meta.preprocessor.string",
            "settings": {
                "foreground": "#eba589"
            }
        },
        {
            "scope": "meta.preprocessor.numeric",
            "settings": {
                "foreground": "#b5cea8"
            }
        },
        {
            "name": "Python dictionary keys to Green Spectrum",
            "scope": "meta.structure.dictionary.key.python",
            "settings": {
                "foreground": "#9aebb8"
            }
        },
        {
            "scope": "meta.diff.header",
            "settings": {
                "foreground": "#55bf60"
            }
        },
        {
            "name": "Control Flow Machinery (async, export, return, import)",
            "scope": [
                "keyword.control",
                "keyword.control.async",
                "keyword.control.export",
                "keyword.control.import",
                "keyword.control.flow",
                "keyword.control.conditional",
                "keyword.control.loop"
            ],
            "settings": {
                "foreground": "#C586c0"
            }
        },
        {
            "name": "Allocation Machinery (let, const, var, function, class)",
            "scope": [
                "storage",
                "storage.type",
                "storage.modifier",
                "keyword.declaration",
                "keyword.other.declaration"
            ],
            "settings": {
                "foreground": "#e09d57"
            }
        },
        {
            "scope": [
                "string",
                "meta.embedded.assembly"
            ],
            "settings": {
                "foreground": "#eba589"
            }
        },
        {
            "scope": "string.tag",
            "settings": {
                "foreground": "#eba589"
            }
        },
        {
            "scope": "string.value",
            "settings": {
                "foreground": "#eba589"
            }
        },
        {
            "scope": "string.regexp",
            "settings": {
                "foreground": "#d16969"
            }
        },
        {
            "name": "String interpolation boundaries",
            "scope": [
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#55bf60"
            }
        },
        {
            "name": "Web styles properties to Green Spectrum",
            "scope": [
                "support.type.vendored.property-name",
                "support.type.property-name",
                "source.css variable",
                "source.coffee.embedded"
            ],
            "settings": {
                "foreground": "#9aebb8"
            }
        },
        {
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#d4cac0"
            }
        },
        {
            "scope": [
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.cast",
                "keyword.operator.sizeof",
                "keyword.operator.alignof",
                "keyword.operator.typeid",
                "keyword.operator.alignas",
                "keyword.operator.instanceof",
                "keyword.operator.logical.python",
                "keyword.operator.wordlike"
            ],
            "settings": {
                "foreground": "#C586c0"
            }
        },
        {
            "scope": "keyword.other.unit",
            "settings": {
                "foreground": "#b5cea8"
            }
        },
        {
            "scope": [
                "punctuation.section.embedded.begin.php",
                "punctuation.section.embedded.end.php"
            ],
            "settings": {
                "foreground": "#C586c0"
            }
        },
        {
            "scope": "support.function.git-rebase",
            "settings": {
                "foreground": "#9aebb8"
            }
        },
        {
            "scope": "constant.sha.git-rebase",
            "settings": {
                "foreground": "#b5cea8"
            }
        },
        {
            "name": "coloring of the Java import and package identifiers",
            "scope": [
                "storage.modifier.import.java",
                "variable.language.wildcard.java",
                "storage.modifier.package.java"
            ],
            "settings": {
                "foreground": "#d4cac0"
            }
        },
        {
            "name": "this.self",
            "scope": "variable.language",
            "settings": {
                "foreground": "#e09d57"
            }
        },
        {
            "name": "High-Contrast Structural Scaffolding Framework (Image Pattern)",
            "scope": [
                "punctuation.separator",
                "punctuation.terminator",
                "punctuation.section.class.begin",
                "punctuation.section.class.end",
                "punctuation.section.block.begin",
                "punctuation.section.block.end",
                "punctuation.section.brackets.begin",
                "punctuation.section.brackets.end",
                "punctuation.section.arguments.begin",
                "punctuation.section.arguments.end",
                "punctuation.section.parameters.begin",
                "punctuation.section.parameters.end",
                "meta.brace.round",
                "meta.brace.square",
                "meta.brace.curly"
            ],
            "settings": {
                "foreground": "#C586c0"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "operator": "#d4cac0",
        "string": "#eba589",
        "number": "#b5cea8"
    }
}