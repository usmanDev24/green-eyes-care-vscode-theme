		<Metadata>
			<Identity Language="en-US" Id="green-eyes-care-theme" Version="3.0.2" Publisher="usmandev24" />
			<DisplayName>Green Eyes Care Theme</DisplayName>
			<Description xml:space="preserve">Dark green theme designed for easy eyes with filtered blue light. Optimized for easy on eyes, natural green, light green and night green mode to provide maximum eye comfort and eyecare"</Description>
			<Tags>green,green theme,dark green,eye-care,nature-green,easy-eyes,zero-blue-light,soft-green,comfort-green,daylight-green,low-contrast,light-green,night-green,eye-comfort,__web_extension</Tags>
			<Categories>Themes</Categories>
			<GalleryFlags>Public</GalleryFlags>
			
